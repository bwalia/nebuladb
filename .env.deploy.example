# Host-port overrides used by the self-hosted `deploy.yml` workflow when
# bringing the stack up on shared infra (e.g. 192.168.1.193) where the
# default ports (8080, 9090, 11434, ...) are already in use by other
# tenants on the box. The deploy job copies this file into `.env` at
# the repo root before `docker compose up`.
#
# Container-side ports stay at their canonical values; only the host-side
# binding changes.

# nebula-server
NEBULA_REST_HOST_PORT=18080
NEBULA_GRPC_HOST_PORT=50051
NEBULA_PG_HOST_PORT=25433

# sidecars
NEBULA_OLLAMA_HOST_PORT=21434
NEBULA_REDIS_HOST_PORT=16379
NEBULA_PROMETHEUS_HOST_PORT=19090
NEBULA_GRAFANA_HOST_PORT=13000
NEBULA_SHOWCASE_PORT=15173

# nebula-follower — same shared-host reason as the leader. The
# compose defaults (8081, 50052) are taken by other tenants on
# this box; without these overrides `docker compose up` fails
# with "Bind for 0.0.0.0:8081 failed: port is already allocated"
# and leaves the follower stuck in Created — which then leaves
# nebula-showcase stuck Restarting because its nginx config
# resolves `nebula-follower:8080` at startup. The deploy.yml run
# for the PR #25 merge failed exactly here.
NEBULA_FOLLOWER_REST_HOST_PORT=18081
NEBULA_FOLLOWER_GRPC_HOST_PORT=50053

# auth + rate-limit knobs (left at defaults; uncomment to enable)
# NEBULA_API_KEYS=secret1,secret2
# NEBULA_RATE_LIMIT=on

# Trust the showcase nginx (and any compose-bridge peer) to set
# X-Forwarded-For so each browser visitor gets its own per-IP
# bucket. Without this, all browsers proxied through showcase
# share one bucket keyed on the showcase container's IP and trip
# 429s on a single active session. Production: list real proxy IPs.
NEBULA_TRUSTED_PROXIES=*

# Bumped from compose defaults (120 burst, 20 rps) because the
# dev stack on 192.168.1.193 hosts the showcase UI for concurrent
# demo users and the defaults trip on chatty SQL/RAG sessions.
NEBULA_RATE_LIMIT_BURST=2000
NEBULA_RATE_LIMIT_RPS=200

# Tokio worker count. Compose default is 8; bump to 16 for
# headroom on the dev box. Searches are offloaded to the blocking
# pool (PR #15) so async workers stay free, but more workers means
# more buffer against pathological bursts.
NEBULA_WORKER_THREADS=16

# Per-db-node cgroup memory cap (leader AND follower). The HNSW arena is
# RAM-resident and grows with the dataset; when it nears the cap a snapshot
# OOM-kills the node. Raise this the moment the NebulaMemoryNearCap (85%)
# alert fires. Live (no recovery): `docker update --memory=<N>g --memory-swap=<N>g
# nebula-server nebula-follower`; durable: set here and redeploy.
# HOST WALL: 192.168.1.193 is 125 GiB and runs BOTH nodes, each holding the
# full arena (~60 GiB each as of 2026-06-03). Keep (leader+follower) caps +
# overhead under ~115 GiB. Once the arena nears ~50 GiB you can't keep
# raising — add RAM, drop the follower (frees ~60 GiB), or land on-disk/
# quantized HNSW. This var buys runway, not a permanent fix.
NEBULA_DB_MEM_LIMIT=80g

# ollama models (first boot pulls these into the volume)
OLLAMA_CHAT_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# ---------------------------------------------------------------------------
# OBSOLETE — do NOT add these to a real `.env` on this host:
#
#   NEBULA_SNAPSHOT_INTERVAL_SECS=0
#   NEBULA_SNAPSHOT_WAL_BYTES=0
#
# These were a temporary workaround for a snapshot-scheduler crash
# loop that PR #25 (`fix/snapshot-streaming-oom`) fixed permanently.
# Leaving them set means the WAL grows unbounded — every cold boot
# re-replays the entire log, peaking memory + extending recovery
# time. On 192.168.1.193 the leader was hitting its 8 GiB cgroup
# cap once the WAL got large enough; the cgroup OOM-killed the
# container and compose restarted it ~every 4 hours.
#
# If your `.env` on the deploy host has these lines, REMOVE them.
# After removal, restart the leader and confirm `nebula_server::
# snapshot_scheduler: ...` log lines appear (instead of "snapshot
# scheduler disabled (no triggers configured)").
# ---------------------------------------------------------------------------
