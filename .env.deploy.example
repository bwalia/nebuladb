# Host-port overrides used by the self-hosted `deploy.yml` workflow when
# bringing the stack up on shared infra (e.g. 192.168.1.193) where the
# default ports (8080, 9090, 11434, ...) are already in use by other
# tenants on the box. The deploy job copies this file into `.env` at
# the repo root before `docker compose up`.
#
# Container-side ports stay at their canonical values; only the host-side
# binding changes.

# nebula-server
NEBULA_REST_HOST_PORT=18080
NEBULA_GRPC_HOST_PORT=50051
NEBULA_PG_HOST_PORT=25433

# sidecars
NEBULA_OLLAMA_HOST_PORT=21434
NEBULA_REDIS_HOST_PORT=16379
NEBULA_PROMETHEUS_HOST_PORT=19090
NEBULA_GRAFANA_HOST_PORT=13000
NEBULA_SHOWCASE_PORT=15173

# auth + rate-limit knobs (left at defaults; uncomment to enable)
# NEBULA_API_KEYS=secret1,secret2
# NEBULA_RATE_LIMIT=on

# Trust the showcase nginx (and any compose-bridge peer) to set
# X-Forwarded-For so each browser visitor gets its own per-IP
# bucket. Without this, all browsers proxied through showcase
# share one bucket keyed on the showcase container's IP and trip
# 429s on a single active session. Production: list real proxy IPs.
NEBULA_TRUSTED_PROXIES=*

# Bumped from compose defaults (120 burst, 20 rps) because the
# dev stack on 192.168.1.193 hosts the showcase UI for concurrent
# demo users and the defaults trip on chatty SQL/RAG sessions.
NEBULA_RATE_LIMIT_BURST=2000
NEBULA_RATE_LIMIT_RPS=200

# Tokio worker count. Compose default is 8; bump to 16 for
# headroom on the dev box. Searches are offloaded to the blocking
# pool (PR #15) so async workers stay free, but more workers means
# more buffer against pathological bursts.
NEBULA_WORKER_THREADS=16

# ollama models (first boot pulls these into the volume)
OLLAMA_CHAT_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text
