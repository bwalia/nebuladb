{
  "title": "NebulaDB — Overview",
  "uid": "nebula-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "tags": ["nebuladb"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Documents indexed",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "nebula_docs_inserted{service=\"nebula-server\"}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Docs deleted",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "nebula_docs_deleted{service=\"nebula-server\"}", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total API requests",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "nebula_requests_total{service=\"nebula-server\"}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Auth failures",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "nebula_auth_failures{service=\"nebula-server\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request rate (per 30s)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(nebula_requests_total{service=\"nebula-server\"}[1m])",
          "refId": "A",
          "legendFormat": "requests/s"
        },
        {
          "expr": "rate(nebula_requests_errors{service=\"nebula-server\"}[1m])",
          "refId": "B",
          "legendFormat": "errors/s"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Search workload (per 30s)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(nebula_searches_vector{service=\"nebula-server\"}[1m])",
          "refId": "A",
          "legendFormat": "vector"
        },
        {
          "expr": "rate(nebula_searches_semantic{service=\"nebula-server\"}[1m])",
          "refId": "B",
          "legendFormat": "semantic"
        },
        {
          "expr": "rate(nebula_rag_requests{service=\"nebula-server\"}[1m])",
          "refId": "C",
          "legendFormat": "rag"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Embedding cache",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(nebula_embed_cache_hits{service=\"nebula-server\"}[1m])",
          "refId": "A",
          "legendFormat": "hits/s"
        },
        {
          "expr": "rate(nebula_embed_cache_misses{service=\"nebula-server\"}[1m])",
          "refId": "B",
          "legendFormat": "misses/s"
        },
        {
          "expr": "rate(nebula_embed_cache_evictions{service=\"nebula-server\"}[1m])",
          "refId": "C",
          "legendFormat": "evictions/s"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Cache hit ratio",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "description": "hits / (hits + misses) over the last 5 minutes",
      "targets": [
        {
          "expr": "sum(rate(nebula_embed_cache_hits{service=\"nebula-server\"}[5m])) / (sum(rate(nebula_embed_cache_hits{service=\"nebula-server\"}[5m])) + sum(rate(nebula_embed_cache_misses{service=\"nebula-server\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Rate limited (total)",
      "gridPos": { "x": 0, "y": 20, "w": 6, "h": 4 },
      "targets": [
        { "expr": "nebula_rate_limited{service=\"nebula-server\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "JWT verification failures",
      "gridPos": { "x": 6, "y": 20, "w": 6, "h": 4 },
      "targets": [
        { "expr": "nebula_jwt_failures{service=\"nebula-server\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Auth + rate-limit events (per 30s)",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 4 },
      "targets": [
        {
          "expr": "rate(nebula_auth_failures{service=\"nebula-server\"}[1m])",
          "refId": "A",
          "legendFormat": "auth_failures/s"
        },
        {
          "expr": "rate(nebula_jwt_failures{service=\"nebula-server\"}[1m])",
          "refId": "B",
          "legendFormat": "jwt_failures/s"
        },
        {
          "expr": "rate(nebula_rate_limited{service=\"nebula-server\"}[1m])",
          "refId": "C",
          "legendFormat": "rate_limited/s"
        }
      ]
    }
  ]
}
